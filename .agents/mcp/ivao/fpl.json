    "/v2/users/{vid}/flightPlans/{id}/archive": {
      "put": {
        "operationId": "FlightPlansController_archive",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "FlightPlan Id",
            "schema": { "type": "number" }
          },
          {
            "name": "vid",
            "required": true,
            "in": "path",
