          },
          "403": {
            "description": "Forbidden",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          }
        },
        "security": [{ "oauth2": [] }, { "consumer": [] }, { "oauth2": [] }, { "oauth2": ["flight_plans:write"] }],
        "tags": ["flightPlans"]
      }
    },
