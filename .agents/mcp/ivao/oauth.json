{
  "openapi": "3.0.0",
  "paths": {
    "/v2/auth/credentials": {
      "post": {
        "operationId": "AuthController_credentials",
        "parameters": [
          {
            "name": "permissions",
            "required": false,
            "in": "query",
            "description": "Include user's permissions in response payload (default: False)",
            "schema": { "type": "boolean" }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Credentials to validate",
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthCredentialsRequestDto" } } }
        },
        "responses": {
          "400": {
            "description": "BadRequest",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          },
          "401": {
            "description": "Forbidden",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          },
          "403": {
            "description": "Forbidden",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          },
          "default": {
            "description": "User information",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/AuthCredentialsResponseDto" } }
            }
          }
        },
        "security": [
          { "oauth2": [] },
          { "consumer": [] },
          { "oauth2": [] },
          { "oauth2": [] },
          { "oauth2": ["profile"] },
          { "oauth2": [] },
          { "consumer": [] }
        ],
        "summary": "Internal use only",
        "tags": ["Internal"]
      }
    },
    "/v2/users/{vid}/oauth/granted-apps": {
      "get": {
        "operationId": "GrantedAppsController_listGrantedApps",
        "parameters": [
          {
            "name": "vid",
            "required": true,
            "in": "path",
            "description": "User's VID (use 'me' for current logged in user)",
            "schema": { "default": "me", "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of granted applications",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/GrantedAppDto" } }
              }
            }
          },
          "400": {
            "description": "BadRequest",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          }
        },
        "summary": "List granted OAuth applications for current user",
        "tags": ["Internal"]
      }
    },
    "/v2/users/{vid}/oauth/granted-apps/{applicationId}": {
      "delete": {
        "operationId": "GrantedAppsController_revokeGrantedApp",
        "parameters": [
          {
            "name": "applicationId",
            "required": true,
            "in": "path",
            "description": "Application ID to revoke access from",
            "schema": { "type": "string" }
          },
          {
            "name": "vid",
            "required": true,
            "in": "path",
            "description": "User's VID (use 'me' for current logged in user)",
            "schema": { "default": "me", "type": "string" }
          }
        ],
        "responses": {
          "400": {
            "description": "BadRequest",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          }
        },
        "summary": "Revoke access to an OAuth application",
        "tags": ["Internal"]
      }
    },
    "/.well-known/jwks.json": {
      "get": {
        "operationId": "JwtController_getKeys",
        "parameters": [],
        "responses": { "200": { "description": "" } },
        "tags": ["Public details"]
      }
    },
    "/.well-known/openid-configuration": {
      "get": {
        "operationId": "JwtController_getOpenidConfiguration",
        "parameters": [],
        "responses": { "200": { "description": "" } },
        "tags": ["Public details"]
      }
    },
    "/v2/oauth/scopes": {
      "get": {
        "operationId": "OAuthScopesController_list",
        "parameters": [
          {
            "name": "ids",
            "required": false,
            "in": "query",
            "description": "Scope ids",
            "schema": { "type": "array", "items": { "type": "string" } }
          }
        ],
        "responses": {
          "200": {
            "description": "Scopes",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/OAuthScopeResponseDto" } }
              }
            }
          }
        },
        "summary": "Internal use only",
        "tags": ["Internal"]
      }
    },
    "/v2/oauth/provision": {
      "post": {
        "operationId": "OAuthProvisionController_provisionCode",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OAuthProvisionRequestDto" } } }
        },
        "responses": { "201": { "description": "" } },
        "summary": "Internal use only",
        "tags": ["Internal"]
      }
    },
    "/v2/oauth/applications/{applicationId}": {
      "get": {
        "operationId": "OAuthApplicationsController_getById",
        "parameters": [
          {
            "name": "applicationId",
            "required": true,
            "in": "path",
            "description": "Application client id",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Application",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/OAuthApplicationResponseDto" } }
            }
          }
        },
        "summary": "Internal use only",
        "tags": ["Internal"]
      }
    },
    "/v2/oauth/applications/{applicationId}/consents/{userId}": {
      "get": {
        "operationId": "OAuthApplicationsController_listConsents",
        "parameters": [
          {
            "name": "userId",
            "required": true,
            "in": "path",
            "description": "User id",
            "schema": { "type": "string" }
          },
          {
            "name": "applicationId",
            "required": true,
            "in": "path",
            "description": "Application id",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Consents",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/OAuthConsentResponseDto" } }
              }
            }
          }
        },
        "summary": "Internal use only",
        "tags": ["Internal"]
      }
    },
    "/v2/oauth/token": {
      "post": {
        "operationId": "OAuthTokenController_token",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OAuthTokenRequestDto" } } }
        },
        "responses": {
          "200": {
            "description": "Created Token",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OAuthTokenResponseDto" } } }
          },
          "400": {
            "description": "BadRequest",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          }
        },
        "tags": ["Token management"]
      }
    },
    "/v2/oauth/token/revoke": {
      "post": {
        "operationId": "OAuthTokenController_revoke",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OAuthTokenRevokeRequestDto" } } }
        },
        "responses": { "200": { "description": "" } },
        "tags": ["Token management"]
      }
    }
  },
  "info": {
    "title": "IVAO OAuth API",
    "description": "IVAO OAuth and SSO related enpoints",
    "version": "1.0",
    "contact": {
      "name": "IVAO Web Services",
      "url": "https://wiki.ivao.aero/en/home/devops/api/documentation-v2",
      "email": "web@ivao.aero"
    }
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "oauth2": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "openIdConnect",
        "openIdConnectUrl": "https://api.ivao.aero/.well-known/openid-configuration"
      },
      "consumer": { "type": "apiKey", "scheme": "https", "in": "header", "name": "apiKey" }
    },
    "schemas": {
      "SwaggerResponsesDto": {
        "type": "object",
        "properties": {
          "statusCode": { "type": "number" },
          "message": { "type": "string" },
          "error": { "type": "string" },
          "error_uri": { "type": "string" }
        },
        "required": ["statusCode", "message", "error", "error_uri"]
      },
      "AuthCredentialsRequestDto": {
        "type": "object",
        "properties": { "username": { "type": "string" }, "password": { "type": "string" } },
        "required": ["username", "password"]
      },
      "NetworkRatingDto": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] },
      "SessionRatingDto": {
        "type": "object",
        "properties": { "name": { "type": "string" }, "shortName": { "type": "string" } },
        "required": ["name", "shortName"]
      },
      "UserAttributesBaseRatingsDto": {
        "type": "object",
        "properties": {
          "atcRatingId": { "type": "number" },
          "networkRatingId": { "type": "number" },
          "pilotRatingId": { "type": "number" },
          "networkRating": { "$ref": "#/components/schemas/NetworkRatingDto" },
          "atcRating": { "$ref": "#/components/schemas/SessionRatingDto" },
          "pilotRating": { "$ref": "#/components/schemas/SessionRatingDto" }
        },
        "required": ["atcRatingId", "networkRatingId", "pilotRatingId", "networkRating", "atcRating", "pilotRating"]
      },
      "UserStaffPositionDto": { "type": "object", "properties": { "id": { "type": "string" } }, "required": ["id"] },
      "AuthCredentialsResponseDto": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "divisionId": { "type": "string" },
          "countryId": { "type": "string" },
          "email": { "type": "string" },
          "rating": { "$ref": "#/components/schemas/UserAttributesBaseRatingsDto" },
          "userStaffPositions": { "type": "array", "items": { "$ref": "#/components/schemas/UserStaffPositionDto" } },
          "permissions": { "type": "array", "items": { "type": "string" } }
        },
        "required": [
          "id",
          "firstName",
          "lastName",
          "divisionId",
          "countryId",
          "email",
          "rating",
          "userStaffPositions",
          "permissions"
        ]
      },
      "UserRefreshTokenDto": {
        "type": "object",
        "properties": { "createdAt": { "format": "date-time", "type": "string" } },
        "required": ["createdAt"]
      },
      "OAuthConsentDto": {
        "type": "object",
        "properties": { "scopeId": { "type": "string" } },
        "required": ["scopeId"]
      },
      "GrantedAppDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "userRefreshTokens": { "type": "array", "items": { "$ref": "#/components/schemas/UserRefreshTokenDto" } },
          "consents": { "type": "array", "items": { "$ref": "#/components/schemas/OAuthConsentDto" } }
        },
        "required": ["id", "name", "userRefreshTokens", "consents"]
      },
      "OAuthScopeResponseDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "isActive": { "type": "boolean" }
        },
        "required": ["id", "description", "isActive"]
      },
      "OAuthProvisionRequestDto": {
        "type": "object",
        "properties": {
          "clientId": { "type": "string" },
          "responseType": { "type": "string" },
          "scope": { "type": "array", "items": { "type": "string" } },
          "userId": { "type": "number" },
          "state": { "type": "string" },
          "redirectUrl": { "type": "string" },
          "codeChallenge": { "type": "string" },
          "codeChallengeMethod": { "type": "string" },
          "nonce": { "type": "string" }
        },
        "required": [
          "clientId",
          "responseType",
          "scope",
          "userId",
          "state",
          "redirectUrl",
          "codeChallenge",
          "codeChallengeMethod",
          "nonce"
        ]
      },
      "OAuthApplicationUserDetailsDto": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" }
        },
        "required": ["id", "firstName", "lastName"]
      },
      "OAuthApplicationDivisionDetailsDto": {
        "type": "object",
        "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "web": { "type": "string" } },
        "required": ["id", "name", "web"]
      },
      "OAuthApplicationVirtualAirlineDetailsDto": {
        "type": "object",
        "properties": { "id": { "type": "number" }, "name": { "type": "string" }, "website": { "type": "string" } },
        "required": ["id", "name", "website"]
      },
      "OAuthApplicationResponseDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "isActive": { "type": "boolean" },
          "redirectUrls": { "type": "array", "items": { "type": "string" } },
          "isHQ": { "type": "boolean" },
          "thirdPartyUserId": { "type": "number" },
          "thirdPartyUser": { "$ref": "#/components/schemas/OAuthApplicationUserDetailsDto" },
          "divisionId": { "type": "string" },
          "division": { "$ref": "#/components/schemas/OAuthApplicationDivisionDetailsDto" },
          "virtualAirlineId": { "type": "number" },
          "virtualAirline": { "$ref": "#/components/schemas/OAuthApplicationVirtualAirlineDetailsDto" },
          "allowOnlyActiveUsersLogin": { "type": "boolean" },
          "createdAt": { "format": "date-time", "type": "string" },
          "updatedAt": { "format": "date-time", "type": "string" }
        },
        "required": [
          "id",
          "name",
          "isActive",
          "redirectUrls",
          "isHQ",
          "thirdPartyUserId",
          "divisionId",
          "virtualAirlineId",
          "allowOnlyActiveUsersLogin",
          "createdAt",
          "updatedAt"
        ]
      },
      "OAuthConsentResponseDto": {
        "type": "object",
        "properties": {
          "userId": { "type": "number" },
          "scopeId": { "type": "string" },
          "applicationId": { "type": "string" }
        },
        "required": ["userId", "scopeId", "applicationId"]
      },
      "OAuthTokenRequestDto": {
        "type": "object",
        "properties": {
          "grant_type": { "type": "string" },
          "code": { "type": "string" },
          "redirect_uri": { "type": "string" },
          "client_id": { "type": "string" },
          "client_secret": { "type": "string" },
          "refresh_token": { "type": "string" },
          "password": { "type": "string" },
          "username": { "type": "string" },
          "scope": { "type": "string" },
          "code_verifier": { "type": "string" },
          "nonce": { "type": "string" }
        },
        "required": [
          "grant_type",
          "code",
          "redirect_uri",
          "client_id",
          "client_secret",
          "refresh_token",
          "password",
          "username",
          "scope",
          "code_verifier",
          "nonce"
        ]
      },
      "OAuthTokenResponseDto": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string" },
          "token_type": { "type": "string" },
          "expires_in": { "type": "number" },
          "refresh_token": { "type": "string" },
          "scope": { "type": "string" }
        },
        "required": ["access_token", "token_type", "expires_in", "refresh_token", "scope"]
      },
      "OAuthTokenRevokeRequestDto": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "token_type_hint": { "type": "string" },
          "client_id": { "type": "string" }
        },
        "required": ["token", "token_type_hint", "client_id"]
      }
    }
  }
}
