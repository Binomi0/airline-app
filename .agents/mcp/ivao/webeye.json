{
  "openapi": "3.0.0",
  "paths": {
    "/v2/webeye/friends": {
      "get": {
        "operationId": "FriendsController_list",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/FriendResponseDto" } }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          },
          "403": {
            "description": "Forbidden",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          }
        },
        "security": [{ "oauth2": [] }, { "oauth2": [] }, { "oauth2": ["friends:read"] }],
        "summary": "List of friends",
        "tags": ["Friends"]
      }
    },
    "/v2/webeye/friends/{vid}": {
      "post": {
        "operationId": "FriendsController_create",
        "parameters": [
          {
            "name": "vid",
            "required": true,
            "in": "query",
            "description": "VID of the friend to add",
            "schema": { "type": "number" }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FriendResponseDto" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          },
          "403": {
            "description": "Forbidden",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          },
          "404": {
            "description": "NotFound",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          }
        },
        "security": [{ "oauth2": [] }, { "oauth2": [] }, { "oauth2": ["friends:write"] }],
        "summary": "Add a friend",
        "tags": ["Friends"]
      },
      "delete": {
        "operationId": "FriendsController_delete",
        "parameters": [
          {
            "name": "vid",
            "required": true,
            "in": "query",
            "description": "VID of the friend to remove",
            "schema": { "type": "number" }
          }
        ],
        "responses": {
          "204": {
            "description": "",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FriendDeleteResponseDto" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          },
          "403": {
            "description": "Forbidden",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          },
          "404": {
            "description": "NotFound",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SwaggerResponsesDto" } } }
          }
        },
        "security": [{ "oauth2": [] }, { "oauth2": [] }, { "oauth2": ["friends:write"] }],
        "summary": "Remove a friend",
        "tags": ["Friends"]
      }
    }
  },
  "info": {
    "title": "IVAO Webeye API",
    "description": "IVAO Webeye Friends Management<br>All endpoints required user authentication",
    "version": "1.0",
    "contact": {
      "name": "IVAO Web Services",
      "url": "https://wiki.ivao.aero/en/home/devops/api/documentation-v2",
      "email": "web@ivao.aero"
    }
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "oauth2": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "openIdConnect",
        "openIdConnectUrl": "https://api.ivao.aero/.well-known/openid-configuration"
      },
      "consumer": { "type": "apiKey", "scheme": "https", "in": "header", "name": "apiKey" }
    },
    "schemas": {
      "SwaggerResponsesDto": {
        "type": "object",
        "properties": {
          "statusCode": { "type": "number" },
          "message": { "type": "string" },
          "error": { "type": "string" },
          "error_uri": { "type": "string" }
        },
        "required": ["statusCode", "message", "error", "error_uri"]
      },
      "FriendUserDto": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "divisionId": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" }
        },
        "required": ["id", "divisionId", "firstName", "lastName"]
      },
      "FriendSessionDto": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "callsign": { "type": "string" },
          "userId": { "type": "number" },
          "connectionType": { "type": "string" },
          "serverId": { "type": "number" },
          "time": { "type": "number" },
          "createdAt": { "format": "date-time", "type": "string" }
        },
        "required": ["id", "callsign", "userId", "connectionType", "serverId", "time", "createdAt"]
      },
      "FriendResponseDto": {
        "type": "object",
        "properties": {
          "userId": { "type": "number" },
          "friendId": { "type": "number" },
          "friend": { "$ref": "#/components/schemas/FriendUserDto" },
          "sessions": { "type": "array", "items": { "$ref": "#/components/schemas/FriendSessionDto" } },
          "createdAt": { "format": "date-time", "type": "string" }
        },
        "required": ["userId", "friendId", "friend", "sessions", "createdAt"]
      },
      "FriendDeleteResponseDto": {
        "type": "object",
        "properties": {
          "userId": { "type": "number" },
          "friendId": { "type": "number" },
          "createdAt": { "format": "date-time", "type": "string" }
        },
        "required": ["userId", "friendId", "createdAt"]
      }
    }
  }
}
